# =============================================================================
# DECOR GRAMAS — .htaccess
# Performance · SEO · URLs Limpas · Segurança
# =============================================================================

Options -Indexes
Options -MultiViews

# =============================================================================
# REWRITE ENGINE — HTTPS + WWW + URLs limpas
# =============================================================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Força HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 2. Força www (canonical com www)
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 3a. Redirects 301: URLs hierárquicas → URLs planas (nova estrutura)
  RewriteRule ^servicos/grama-sintetica-jardim(/?)$ /grama-sintetica-jardim [R=301,L]
  RewriteRule ^servicos/grama-sintetica-decorativa(/?)$ /grama-sintetica-decorativa [R=301,L]
  RewriteRule ^servicos/grama-sintetica-para-pets(/?)$ /grama-sintetica-para-pets [R=301,L]
  RewriteRule ^servicos/grama-sintetica-para-piscina(/?)$ /grama-sintetica-para-piscina [R=301,L]
  RewriteRule ^servicos/grama-sintetica-para-varanda(/?)$ /grama-sintetica-para-varanda [R=301,L]
  RewriteRule ^servicos/playground-em-grama-sintetica(/?)$ /playground-em-grama-sintetica [R=301,L]
  RewriteRule ^cidades/grama-sintetica-brusque(/?)$ /grama-sintetica-brusque [R=301,L]
  RewriteRule ^cidades/grama-sintetica-itajai(/?)$ /grama-sintetica-itajai [R=301,L]
  RewriteRule ^cidades/grama-sintetica-blumenau(/?)$ /grama-sintetica-blumenau [R=301,L]
  RewriteRule ^cidades/grama-sintetica-balneario-camboriu(/?)$ /grama-sintetica-balneario-camboriu [R=301,L]
  RewriteRule ^cidades/grama-sintetica-gaspar(/?)$ /grama-sintetica-gaspar [R=301,L]
  RewriteRule ^cidades/grama-sintetica-timbo(/?)$ /grama-sintetica-timbo [R=301,L]
  RewriteRule ^cidades/grama-sintetica-pomerode(/?)$ /grama-sintetica-pomerode [R=301,L]
  RewriteRule ^cidades/grama-sintetica-itapema(/?)$ /grama-sintetica-itapema [R=301,L]

  # 3b. Rewrites internos: URLs planas → arquivos físicos
  RewriteRule ^grama-sintetica-jardim$ servicos/grama-sintetica-jardim.html [L]
  RewriteRule ^grama-sintetica-decorativa$ servicos/grama-sintetica-decorativa.html [L]
  RewriteRule ^grama-sintetica-para-pets$ servicos/grama-sintetica-para-pets.html [L]
  RewriteRule ^grama-sintetica-para-piscina$ servicos/grama-sintetica-para-piscina.html [L]
  RewriteRule ^grama-sintetica-para-varanda$ servicos/grama-sintetica-para-varanda.html [L]
  RewriteRule ^playground-em-grama-sintetica$ servicos/playground-em-grama-sintetica.html [L]
  RewriteRule ^grama-sintetica-brusque$ cidades/grama-sintetica-brusque.html [L]
  RewriteRule ^grama-sintetica-itajai$ cidades/grama-sintetica-itajai.html [L]
  RewriteRule ^grama-sintetica-blumenau$ cidades/grama-sintetica-blumenau.html [L]
  RewriteRule ^grama-sintetica-balneario-camboriu$ cidades/grama-sintetica-balneario-camboriu.html [L]
  RewriteRule ^grama-sintetica-gaspar$ cidades/grama-sintetica-gaspar.html [L]
  RewriteRule ^grama-sintetica-timbo$ cidades/grama-sintetica-timbo.html [L]
  RewriteRule ^grama-sintetica-pomerode$ cidades/grama-sintetica-pomerode.html [L]
  RewriteRule ^grama-sintetica-itapema$ cidades/grama-sintetica-itapema.html [L]

  # 3c. Remove /index.html da URL (301 permanente)
  RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[\s?] [NC]
  RewriteRule ^(.*/)?index\.html$ /%1 [R=301,L,NE]

  # 4. Remove extensão .html da URL (301 permanente)
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^(.+?)\.html$ /$1 [R=301,L,NE]

  # 5. Serve o .html internamente para URLs sem extensão
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]
</IfModule>

# =============================================================================
# COMPRESSÃO GZIP / BROTLI
# =============================================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2
  AddOutputFilterByType DEFLATE application/font-woff
  AddOutputFilterByType DEFLATE application/font-woff2
</IfModule>

# =============================================================================
# BROWSER CACHE — Expires
# =============================================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                          "access plus 1 month"

  # HTML — curto (conteúdo muda com frequência)
  ExpiresByType text/html                 "access plus 1 hour"

  # CSS e JS — 1 ano (usar query string ?v=x ao atualizar)
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType text/javascript           "access plus 1 year"

  # Imagens — 1 ano
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/gif                 "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"

  # Fontes — 1 ano
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType application/font-woff     "access plus 1 year"
  ExpiresByType application/font-woff2    "access plus 1 year"

  # XML / JSON
  ExpiresByType application/xml           "access plus 1 day"
  ExpiresByType text/xml                  "access plus 1 day"
  ExpiresByType application/json          "access plus 0 seconds"
</IfModule>

# Cache-Control granular
<IfModule mod_headers.c>
  <FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|svg|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# =============================================================================
# SEGURANÇA — Headers
# =============================================================================
<IfModule mod_headers.c>
  Header always set X-Frame-Options          "SAMEORIGIN"
  Header always set X-Content-Type-Options   "nosniff"
  Header always set X-XSS-Protection         "1; mode=block"
  Header always set Referrer-Policy          "strict-origin-when-cross-origin"
  Header always set Permissions-Policy       "geolocation=(), microphone=(), camera=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>

# =============================================================================
# SEGURANÇA — Proteção de arquivos sensíveis
# =============================================================================
<FilesMatch "(\.htaccess|\.htpasswd|\.env|\.git|\.log|\.sh|\.ini)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# =============================================================================
# PROTEÇÃO HOTLINK — Bloqueia uso das imagens por outros sites
# =============================================================================
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_REFERER} !^$
  RewriteCond %{HTTP_REFERER} !^https?://(www\.)?decorgramas\.com\.br [NC]
  RewriteCond %{HTTP_REFERER} !^https?://localhost [NC]
  RewriteRule \.(webp|jpg|jpeg|png|gif|svg)$ - [F,NC]
</IfModule>

# =============================================================================
# TIPOS MIME
# =============================================================================
<IfModule mod_mime.c>
  AddType image/webp          .webp
  AddType font/woff           .woff
  AddType font/woff2          .woff2
  AddType application/json    .json
  AddType image/svg+xml       .svg
</IfModule>

# =============================================================================
# PÁGINAS DE ERRO PERSONALIZADAS (descomentar quando criar as páginas)
# =============================================================================
# ErrorDocument 404 /404.html
# ErrorDocument 500 /500.html
